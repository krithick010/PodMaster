# KubeVision AI Environment Configuration

# Prometheus Configuration - Using kube-prometheus stack (has kube-state-metrics)
PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_SCRAPE_INTERVAL=10

# Kubernetes Configuration
KUBECONFIG=~/.kube/config

# OpenRouter Configuration (primary LLM — used by InsightGenerator AND agent pipeline)
OPENROUTER_API_KEY=giveapikeyfromconsole.groq.com
OPENROUTER_MODEL=openrouter/auto

# Agent Pipeline LLM Configuration (langchain-openai pointing at OpenRouter)
AGENT_LLM_BASE_URL=https://api.groq.com/openai/v1
AGENT_LLM_MODEL=llama-3.1-8b-instant


# Ollama LLM Configuration (optional - will fallback to templates if not available)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3.5:latest
OLLAMA_TIMEOUT=30

# Database Configuration
DB_PATH=./kubevision.db
DB_RETENTION_DAYS=7

# Collection Configuration
COLLECTION_INTERVAL=10

# Agent Thresholds
CPU_WARNING_THRESHOLD=0.80
CPU_CRITICAL_THRESHOLD=0.95
MEMORY_WARNING_THRESHOLD=0.80
MEMORY_CRITICAL_THRESHOLD=0.95
STORAGE_WARNING_THRESHOLD=0.80
STORAGE_CRITICAL_THRESHOLD=0.90

# Network Thresholds
NETWORK_WARNING_MB_S=10
NETWORK_CRITICAL_MB_S=50

# Log Error Thresholds
LOG_ERROR_WARNING_PER_S=1.0
LOG_ERROR_CRITICAL_PER_S=2.0

# Pod Scheduling Thresholds
PENDING_WARNING_SECONDS=60
PENDING_CRITICAL_SECONDS=120

# Chaos Engine Configuration
CHAOS_AUTO_RECOVER_SECONDS=90

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000

# Logging
LOG_LEVEL=INFO
